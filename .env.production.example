# PRODUCTION ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill with your production values

# Database Configuration
POSTGRES_USER=systemagt_user
POSTGRES_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD
POSTGRES_DB=systemagt_db

# JWT Configuration (generate with: openssl rand -base64 32)
JWT_SECRET=CHANGE_THIS_TO_SECURE_JWT_SECRET_MIN_32_CHARS

# WhatsApp API Configuration
WHATSAPP_API_URL=https://wtsapi.duckdns.org/enviar

# Domain Configuration
DOMAIN=systemagt.duckdns.org

# Optional: Email for Let's Encrypt notifications
LETSENCRYPT_EMAIL=fernandochamussola@gmail.com

# Email Configuration (Gmail SMTP)
# Para obter o App Password do Gmail:
# 1. Acesse sua conta Google > Segurança
# 2. Ative a verificação em duas etapas
# 3. Vá em "Senhas de app" e crie uma nova senha
EMAIL_USER=your_email@gmail.com
EMAIL_APP_PASSWORD=your_gmail_app_password
